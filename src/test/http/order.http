### 0. 사전 준비 (로그인 상태 확인)
# 다른 파일(auth.http)에서 로그인을 먼저 실행해서 {{token}} 값을 세팅해두어야 합니다.

### 1. 상품 바로 주문 (단건)
POST http://localhost:8080/api/orders
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "productId": 1,
  "quantity": 1,
  "usePointAmount": 1000
}

> {%
    client.test("응답 성공 검증", function () {
        client.assert(response.status === 200, "Expected 200 OK");
    });
    // 다음 결제 테스트를 위해 paymentId 저장
    if (response.status === 200) {
        client.global.set("paymentId", response.body.data.paymentId);
        client.log("Saved paymentId: " + client.global.get("paymentId"));
    }
%}

###

### 2. 장바구니 주문 생성
POST http://localhost:8080/api/carts/orders
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "cartItemIds": [1, 2],
  "usePointAmount": 0
}
